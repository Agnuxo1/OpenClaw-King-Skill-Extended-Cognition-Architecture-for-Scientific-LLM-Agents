"""
LLM Client for {{ full_name }} ({{ codename }}).

Primary provider: {{ llm_provider }} / {{ llm_model }}
Fallback: HuggingFace Inference API (Qwen2.5-72B)
"""

import os
import time
import httpx
from typing import Optional

# ── Primary provider: {{ llm_provider }} ─────────────────────────────────────
{% if llm_provider == "groq" %}
_PRIMARY_KEY  = os.getenv("{{ llm_env_var }}", "")
_PRIMARY_BASE = "https://api.groq.com/openai/v1"
_PRIMARY_MODEL = "{{ llm_model }}"
_PRIMARY_NAME  = "Groq"

def _try_primary(messages: list, max_tokens: int, temperature: float) -> Optional[str]:
    if not _PRIMARY_KEY:
        return None
    try:
        r = httpx.post(
            f"{_PRIMARY_BASE}/chat/completions",
            headers={"Authorization": f"Bearer {_PRIMARY_KEY}", "Content-Type": "application/json"},
            json={"model": _PRIMARY_MODEL, "messages": messages,
                  "max_tokens": max_tokens, "temperature": temperature},
            timeout=90.0,
        )
        if r.status_code == 429:
            time.sleep(60)
            return None
        r.raise_for_status()
        return r.json()["choices"][0]["message"]["content"].strip()
    except Exception:
        return None

