# ── Startup: launch agent ──────────────────────────────────────────────────────
@app.on_event("startup")
async def on_startup():
    def _start():
        time.sleep(2)
        agent = _ensure_agent()
        agent.start()
    threading.Thread(target=_start, daemon=True).start()


# ── Entrypoint ─────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    uvicorn.run(
        "app:app",
        host="0.0.0.0",
        port=int(os.getenv("PORT", "7860")),
        log_level="warning",
    )
